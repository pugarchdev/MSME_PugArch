# Root workspace environment example

# Backend runtime values live in backend/.env.example.
# Frontend runtime values live in frontend/.env.example.

# Local smoke tests
PORTAL_API_URL=http://localhost:5001
PORTAL_AUTH_TOKEN=

# Optional database-backed tests. Never point TEST_DATABASE_URL at production.
RUN_DB_INTEGRATION=0
TEST_DATABASE_URL=
RUN_REDIS_INTEGRATION=0
TEST_REDIS_URL=
