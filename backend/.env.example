NODE_ENV=development
PORT=5001
VERCEL_ENV=

# Create separate env files per environment outside git:
# - backend/.env.development.local
# - backend/.env.staging.local
# - backend/.env.production.local
# Load them through your deployment platform or secret manager.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DB_KEEPALIVE=false

# Use at least 32 random characters. Never commit real secrets.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_COST=12
FAILED_LOGIN_LOCK_THRESHOLD=5
FAILED_LOGIN_LOCK_MINUTES=30
MASTER_ADMIN_EMAIL=master-admin@example.com
MASTER_ADMIN_PASSWORD=replace-with-strong-master-admin-password
MASTER_ADMIN_NAME=Master Admin

# Local development: FRONTEND_URL=http://localhost:3000
# Production: set this to your deployed frontend URL (e.g. https://msme-pugarch-frontend.vercel.app)
# This is used for post-KYC callback redirects — an incorrect value here will send the user to the wrong page.
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174,https://msme-pugarch-frontend.vercel.app
CORS_ALLOW_VERCEL_PREVIEWS=false
REQUEST_BODY_LIMIT=1mb

REDIS_URL=redis://localhost:6379
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_PREFIX=msme:
# Use redis for Redis or Valkey-compatible deployments; use memory only for local fallback.
CACHE_DRIVER=redis
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOCK_FALLBACK_ALLOW=false
LOG_LEVEL=info

STORAGE_PROVIDER=cloudinary
PAYMENT_PROVIDER=bank_transfer
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
BANK_TRANSFER_VIRTUAL_ACCOUNT=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GCP_STORAGE_BUCKET=
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_JSON=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

SMS_ENABLED=false
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_BASE_URL=https://control.msg91.com
MSG91_COMMON_OTP_TEMPLATE_ID=

APISETU_API_KEY=
APISETU_CLIENT_ID=
APISETU_GST_URL=https://apisetu.gov.in/gstn/v2/taxpayers/{gstin}
APISETU_GST_METHOD=GET
APISETU_CA_CERT=
APISETU_ALLOW_INSECURE_TLS=false
GST_APISETU_APIKEY=
GST_APISETU_CLIENTID=

# MeriPehchaan / API Setu Auth Partner Aadhaar KYC.
# Use values from the API Setu Auth Partner dashboard or documentation.
# Never commit real client secrets or production endpoints here.
MERIPEHCHAAN_CLIENT_ID=
MERIPEHCHAAN_CLIENT_SECRET=
MERIPEHCHAAN_AUTH_URL=
MERIPEHCHAAN_TOKEN_URL=
MERIPEHCHAAN_USERINFO_URL=
# REQUIRED when MERIPEHCHAAN_SCOPES includes 'openid' (id_token verification).
# Obtain from the API Setu / MeriPehchaan OIDC discovery document or dashboard.
# Example discovery URL: https://digilocker.meripehchaan.gov.in/.well-known/openid-configuration
MERIPEHCHAAN_JWKS_URL=
# Recommended: set to the issuer value from the OIDC discovery document.
MERIPEHCHAAN_ISSUER=
# Callback URL — must exactly match the redirect URI registered in the API Setu Auth Partner dashboard.
# Production: MERIPEHCHAAN_REDIRECT_URI=https://YOUR_BACKEND_DOMAIN/api/kyc/aadhaar/callback
# Local dev:  MERIPEHCHAAN_REDIRECT_URI=http://localhost:5001/api/kyc/aadhaar/callback
MERIPEHCHAAN_REDIRECT_URI=https://YOUR_BACKEND_DOMAIN/api/kyc/aadhaar/callback
MERIPEHCHAAN_SCOPES=openid
MERIPEHCHAAN_ACR=

# Standard OIDC discovery variables (mapped to the above MERIPEHCHAAN_ variables)
# authorization_endpoint=
# token_endpoint=
# userinfo_endpoint=
# jwks_uri=
# issuer=
AADHAAR_KYC_SESSION_TTL_MINUTES=60

DELIVERY_AUTO_SEED=false

# Test/smoke-only values. Do not point TEST_DATABASE_URL at production.
RUN_DB_INTEGRATION=0
TEST_DATABASE_URL=
RUN_REDIS_INTEGRATION=0
TEST_REDIS_URL=
PORTAL_API_URL=http://localhost:5001
PORTAL_AUTH_TOKEN=

# Production requirements:
# NODE_ENV=production
# FRONTEND_URL=https://msme-pugarch-frontend.vercel.app
# CORS_ALLOWED_ORIGINS=https://msme-pugarch-frontend.vercel.app
# DATABASE_URL must point to private-network PostgreSQL where possible.
# REDIS_URL or REDIS_HOST must point to private-network Redis where possible.
# JWT_SECRET must be at least 32 random characters.
# STORAGE_PROVIDER credentials must match the selected provider.
# PAYMENT_PROVIDER credentials and webhook secret must match the selected gateway.
# SMTP credentials are required for production OTP/email delivery.
# LOG_LEVEL must be info, warn, or error in production.
# AI Providers Configuration
AI_PROVIDER_PRIORITY=gemini,nvidia,ollama
AI_REQUEST_TIMEOUT_MS=20000
NVIDIA_API_KEY=
NVIDIA_MODEL=minimaxai/minimax-m3
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
