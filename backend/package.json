{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsc -p tsconfig.json && node dist/index.js",
    "postinstall": "npx prisma generate",
    "db:migrate": "npx prisma migrate deploy",
    "vercel-build": "npx prisma generate && tsc",
    "build": "npx prisma generate && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "lint:security": "eslint index.ts src --ext .ts --max-warnings=0",
    "prisma:validate": "npx prisma validate",
    "test:security": "node --test tests/security.test.mjs tests/phase8.integration.test.mjs tests/delivery.test.mjs tests/buyer-happy-path.test.mjs tests/route-consolidation.test.mjs",
    "test:integration": "node --test tests/phase8.integration.test.mjs",
    "test:delivery": "node --test tests/delivery.test.mjs",
    "audit:deps": "npm audit --workspace=backend --audit-level=high",
    "db:empty-preserve-admins": "tsx scripts/empty-db-preserve-admins.ts",
    "cleanup:seed-data": "tsx scripts/cleanup-seed-data.ts",
    "backfill:org-membership": "tsx scripts/backfill-org-membership.ts",
    "attach-user-to-org": "tsx scripts/attach-user-to-org.ts",
    "security:check": "npm run typecheck && npm run prisma:validate && npm run lint:security && npm run test:security && npm run audit:deps",
    "vercel-build:with-migrate": "npm run db:migrate && npm run vercel-build"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^6.19.3"
  }
}
