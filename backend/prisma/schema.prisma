  ipAddress          String?
  userAgent          String?
  fileAssetId        Int?
  metadata           Json?
  createdAt          DateTime         @default(now())
  deliveryTracking   DeliveryTracking @relation(fields: [deliveryTrackingId], references: [id], onDelete: Cascade)
