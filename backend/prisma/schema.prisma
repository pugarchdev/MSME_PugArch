  warranty          String?
  validTill         DateTime?
  note              String?
  documentUrl       String?
  fileAssetId       Int?
  bidNumber         String?    @unique
  withdrawnAt       DateTime?
  modifiedAt        DateTime?
  lastIpAddress     String?
  lastUserAgentHash String?
  deviceHash        String?
