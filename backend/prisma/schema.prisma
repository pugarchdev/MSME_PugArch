  updatedAt        DateTime       @updatedAt
  Tender           Tender         @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  winnerSeller     User?          @relation("AuctionWinner", fields: [winnerSellerId], references: [id], onDelete: SetNull)
  currentWinner    User?          @relation("AuctionCurrentWinner", fields: [currentWinnerId], references: [id], onDelete: SetNull)
  bids             AuctionBid[]

  @@index([status, endTime])
  @@index([statusEnum])
  @@index([winnerSellerId])
  @@index([currentWinnerId])
}

model AuctionBid {
  id            Int      @id @default(autoincrement())
  auctionId     Int
  sellerId      Int
  bidAmount     Float
  ipAddress     String?
  userAgentHash String?
  deviceHash    String?
