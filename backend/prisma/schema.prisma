  createdAt    DateTime                      @default(now())

  bid        ProcurementBid @relation(fields: [bidId], references: [id], onDelete: Cascade)
  uploadedBy User           @relation("ProcurementBidDocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([bidId, visibility])
  @@index([uploadedById])
}

model ProcurementBidParticipation {
  id                     Int                         @id @default(autoincrement())
  bidId                  Int
  sellerId               Int
  participationNumber    String                      @unique
  technicalStatus        ProcurementTechnicalStatus  @default(PENDING)
  financialStatus        ProcurementFinancialStatus  @default(LOCKED)
  finalStatus            ProcurementFinalStatus      @default(PENDING)
  rank                   Int?
  quotedAmount           Decimal?                    @db.Decimal(18, 2)
  gstPercentage          Decimal?                    @db.Decimal(5, 2)
  totalAmount            Decimal?                    @db.Decimal(18, 2)
  makeBrand              String?
  model                  String?
  offeredItemDescription String?
  submissionStatus       ProcurementSubmissionStatus @default(DRAFT)
  submittedAt            DateTime?
  technicalSubmittedAt   DateTime?
  financialSubmittedAt   DateTime?
  isWithdrawn            Boolean                     @default(false)
  withdrawnAt            DateTime?
  rejectionReason        String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  bid            ProcurementBid                        @relation(fields: [bidId], references: [id], onDelete: Cascade)
  seller         User                                  @relation("ProcurementBidParticipationSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  documents      ProcurementBidParticipationDocument[]
  clarifications ProcurementBidClarification[]
  evaluations    ProcurementBidEvaluation[]
  awards         ProcurementBidAward[]

  @@unique([bidId, sellerId])
  @@index([sellerId, submissionStatus])
  @@index([bidId, technicalStatus, financialStatus])
  @@index([submissionStatus])
  @@index([submittedAt])
}

model ProcurementBidParticipationDocument {
  id               Int                         @id @default(autoincrement())
