  fileAsset          FileAsset?       @relation("DeliveryStatusLogFile", fields: [fileAssetId], references: [id], onDelete: SetNull)

  @@index([deliveryTrackingId])
  @@index([changedById])
  @@index([newStatus])
  @@index([createdAt])
}

model DeliveryDocument {
  id                 Int                  @id @default(autoincrement())
  deliveryTrackingId Int
  fileAssetId        Int
  documentType       DeliveryDocumentType
  uploadedById       Int
  uploaderRole       String
  description        String?
  createdAt          DateTime             @default(now())
  deliveryTracking   DeliveryTracking     @relation(fields: [deliveryTrackingId], references: [id], onDelete: Cascade)
  fileAsset          FileAsset            @relation("DeliveryDocumentFile", fields: [fileAssetId], references: [id], onDelete: Cascade)
  uploadedBy         User                 @relation("DeliveryDocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([deliveryTrackingId])
  @@index([fileAssetId])
  @@index([documentType])
  @@index([uploadedById])
