generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                 Int                                   @id @default(autoincrement())
  name                               String
  email                              String                                @unique
  userId                             String?                               @unique
  password                           String
  role                               Role
  registrationStatus                 RegistrationStatus                    @default(incomplete)
  onboardingStatus                   OnboardingStatus                      @default(pending)
  sectionStatus                      Json?
  sectionRejectionReasons            Json?
  registrationDetails                Json?
  adminFeedback                      String?                               @default("")
  mobile                             String?
  dob                                DateTime?
  isDualRole                         Boolean                               @default(false)
  emailVerified                      Boolean                               @default(false)
  mobileVerified                     Boolean                               @default(false)
  twoFactorEnabled                   Boolean                               @default(false)
  failedLoginCount                   Int                                   @default(0)
  lockedUntil                        DateTime?
  lastLoginAt                        DateTime?
  lastPasswordChangeAt               DateTime?
  passwordResetVersion               Int                                   @default(0)
  sessionVersion                     Int                                   @default(0)
  organizationId                     Int?
  companyId                          Int?
  accountStatus                      UserStatus                            @default(ACTIVE)
  createdAt                          DateTime                              @default(now())
  updatedAt                          DateTime                              @updatedAt
  Approval                           Approval[]
  AuditLog                           AuditLog[]
  complianceViolations               ComplianceViolation[]
  fileAssets                         FileAsset[]
  idempotencyKeys                    IdempotencyKey[]
  loginEvents                        LoginEvent[]
  escrowAccountsAsBuyer              EscrowAccount[]                       @relation("EscrowBuyer")
  escrowAccountsAsSeller             EscrowAccount[]                       @relation("EscrowSeller")
  milestoneApprovals                 MilestoneApproval[]
  paymentsAsPayee                    PaymentTransaction[]                  @relation("PaymentPayee")
  paymentsAsPayer                    PaymentTransaction[]                  @relation("PaymentPayer")
  auctionBids                        AuctionBid[]
  auctionWins                        Auction[]                             @relation("AuctionWinner")
  currentAuctionWins                 Auction[]                             @relation("AuctionCurrentWinner")
  buyerConversations                 Conversation[]                        @relation("BuyerConversations")
  sellerConversations                Conversation[]                        @relation("SellerConversations")
  sentMessages                       Message[]                             @relation("MessageSender")
  buyerDisputes                      Dispute[]                             @relation("BuyerDisputes")
  sellerDisputes                     Dispute[]                             @relation("SellerDisputes")
  raisedDisputes                     Dispute[]                             @relation("RaisedDisputes")
  resolvedDisputes                   Dispute[]                             @relation("ResolvedDisputes")
  assignedDisputes                   Dispute[]                             @relation("AssignedDisputes")
  disputeMessages                    DisputeMessage[]                      @relation("DisputeMessageSender")
  disputeEvidenceUploads             DisputeEvidence[]                     @relation("DisputeEvidenceUploader")
  disputeAttachmentsUploaded         DisputeAttachment[]                   @relation("DisputeAttachmentUploader")
  grievances                         GrievanceTicket[]                     @relation("GrievanceOwner")
  assignedGrievances                 GrievanceTicket[]                     @relation("GrievanceAssignee")
  grievanceComments                  GrievanceComment[]                    @relation("GrievanceCommentAuthor")
  grievanceUploads                   GrievanceAttachment[]                 @relation("GrievanceAttachmentUploader")
  bids                               Bid[]
  buyerProfile                       BuyerProfile?
  buyerInvoices                      Invoice[]                             @relation("BuyerInvoices")
  buyerPurchaseOrders                PurchaseOrder[]                       @relation("BuyerPurchaseOrders")
  sentRequests                       QuoteRequest[]                        @relation("BuyerRequests")
  receivedRequests                   QuoteRequest[]                        @relation("SellerRequests")
  sellerInvoices                     Invoice[]                             @relation("SellerInvoices")
  sellerPurchaseOrders               PurchaseOrder[]                       @relation("SellerPurchaseOrders")
  sellerProfile                      SellerProfile?
  tenders                            Tender[]
  organization                       Organization?                         @relation(fields: [organizationId], references: [id])
  company                            Company?                              @relation(fields: [companyId], references: [id])
  roles                              UserRole[]                            @relation("UserRoleUser")
  assignedUserRoles                  UserRole[]                            @relation("UserRoleAssigner")
  updatedCompanyFeatures             CompanyFeature[]                      @relation("CompanyFeatureUpdater")
  sessions                           UserSession[]
  sellerDocumentsVerified            SellerDocument[]                      @relation("SellerDocumentVerifiedBy")
  shgProfile                         ShgProfile?                          @relation("ShgPrimaryUser")
  apiVerificationLogs                ApiVerificationLog[]
  apiLogs                            ApiLog[]
  fraudAlerts                        FraudAlert[]                          @relation("FraudAlertUser")
  reviewedFraudAlerts                FraudAlert[]                          @relation("FraudAlertReviewedBy")
  products                           Product[]                             @relation("ProductSeller")
  services                           Service[]                             @relation("ServiceSeller")
  requirements                       Requirement[]                         @relation("RequirementBuyer")
  directPurchasesAsBuyer             DirectPurchase[]                      @relation("DirectPurchaseBuyer")
  directPurchasesAsSeller            DirectPurchase[]                      @relation("DirectPurchaseSeller")
  quoteResponses                     QuoteResponse[]                       @relation("QuoteResponseSeller")
  tenderParticipants                 TenderParticipant[]                   @relation("TenderParticipantSeller")
  technicalEvaluations               TechnicalEvaluationResult[]           @relation("TechnicalEvaluationEvaluator")
  financialEvaluations               FinancialEvaluation[]                 @relation("FinancialEvaluationEvaluator")
  supplierRatingsGiven               SupplierRating[]                      @relation("SupplierRatingBuyer")
  supplierRatingsReceived            SupplierRating[]                      @relation("SupplierRatingSeller")
  buyerRatingsGiven                  BuyerRating[]                         @relation("BuyerRatingSeller")
  buyerRatingsReceived               BuyerRating[]                         @relation("BuyerRatingBuyer")
  notifications                      Notification[]
  notificationPreference             NotificationPreference?
  deliveryStatusLogs                 DeliveryStatusLog[]                   @relation("DeliveryStatusLogActor")
  deliveryDocumentsUploaded          DeliveryDocument[]                    @relation("DeliveryDocumentUploader")
  deliveryParticipantRoles           DeliveryParticipant[]                 @relation("DeliveryParticipantUser")
  deliveryParticipantsAssigned       DeliveryParticipant[]                 @relation("DeliveryParticipantAssignedBy")
  buyerAcceptances                   BuyerAcceptance[]                     @relation("BuyerAcceptanceActor")
  paymentSettlementsVerified         PaymentSettlement[]                   @relation("PaymentSettlementInvoiceVerifier")
  paymentSettlementsApproved         PaymentSettlement[]                   @relation("PaymentSettlementApprover")
  paymentSettlementsReleased         PaymentSettlement[]                   @relation("PaymentSettlementReleaser")
  paymentSettlementsRejected         PaymentSettlement[]                   @relation("PaymentSettlementRejecter")
  orgMemberships                     OrgMembership[]                       @relation("OrgMembershipUser")
  orgMembershipsInvited              OrgMembership[]                       @relation("OrgMembershipInviter")
  orgMembershipsTransferred          OrgMembership[]                       @relation("OrgMembershipTransferSource")
  orgMembershipsDeactivated          OrgMembership[]                       @relation("OrgMembershipDeactivator")
  orgInvitationsSent                 OrgInvitation[]                       @relation("OrgInvitationInviter")
  orgCustomRolesCreated              OrgCustomRole[]                       @relation("OrgCustomRoleCreator")
  accessTransfersFrom                AccessTransferLog[]                   @relation("AccessTransferFromUser")
  accessTransfersTo                  AccessTransferLog[]                   @relation("AccessTransferToUser")
  accessTransfersPerformed           AccessTransferLog[]                   @relation("AccessTransferPerformer")
  cartsCreated                       Cart[]                                @relation("CartCreator")
  cartsApproved                      Cart[]                                @relation("CartApprover")
  cartsRejected                      Cart[]                                @relation("CartRejecter")
  cartItemsAsSeller                  CartItem[]                            @relation("CartItemSeller")
  cartItemsTechApproved              CartItem[]                            @relation("CartItemTechApprover")
  buyerRequirementsCreated           BuyerRequirement[]                    @relation("BuyerRequirementCreator")
  buyerRequirementsApproved          BuyerRequirement[]                    @relation("BuyerRequirementApprover")
  requirementResponses               RequirementResponse[]                 @relation("RequirementResponseSeller")
  procurementApprovalsDecided        ProcurementApproval[]                 @relation("ProcurementApprovalApprover")
  grnsReceived                       GoodsReceiptNote[]                    @relation("GrnReceiver")
  grnDocumentsUploaded               GrnDocument[]                         @relation("GrnDocumentUploader")
  procurementBidsCreated             ProcurementBid[]                      @relation("ProcurementBidCreatedBy")
  procurementBidsApproved            ProcurementBid[]                      @relation("ProcurementBidApprovedBy")
  procurementBidDocuments            ProcurementBidDocument[]              @relation("ProcurementBidDocumentUploader")
  procurementParticipations          ProcurementBidParticipation[]         @relation("ProcurementBidParticipationSeller")
  procurementParticipationDocuments  ProcurementBidParticipationDocument[] @relation("ProcurementBidParticipationDocumentUploader")
  procurementClarificationsAsSeller  ProcurementBidClarification[]         @relation("ProcurementBidClarificationSeller")
  procurementClarificationsAsBuyer   ProcurementBidClarification[]         @relation("ProcurementBidClarificationBuyer")
  procurementClarificationsRequested ProcurementBidClarification[]         @relation("ProcurementBidClarificationRequestedBy")
  procurementClarificationsResponded ProcurementBidClarification[]         @relation("ProcurementBidClarificationRespondedBy")
  procurementClarificationFiles      ProcurementBidClarificationFile[]     @relation("ProcurementBidClarificationFileUploader")
  procurementEvaluations             ProcurementBidEvaluation[]            @relation("ProcurementBidEvaluationEvaluator")
  procurementAwardsAsSeller          ProcurementBidAward[]                 @relation("ProcurementBidAwardSeller")
  procurementAwardsGranted           ProcurementBidAward[]                 @relation("ProcurementBidAwardedBy")
  procurementAuditLogs               ProcurementAuditLog[]                 @relation("ProcurementAuditUser")
  marketplaceInteractions            MarketplaceInteraction[]              @relation("MarketplaceInteractionUser")

  @@index([role, onboardingStatus])
  @@index([role])
  @@index([mobile])
  @@index([organizationId])
  @@index([companyId])
  @@index([accountStatus])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([onboardingStatus])
  @@index([name])
}

model BuyerProfile {
  id                      Int                 @id @default(autoincrement())
  userId                  Int                 @unique
  organizationId          Int?
  organizationName        String
  businessType            String
  msmeType                String?
  organizationType        String?
  ministry                String?
  division                String?
  employeeCount           String?
  organizationTypeEnum    OrganizationType?
  verificationStatusEnum  VerificationStatus?
  industry                String?
  cin                     String?
  pan                     String?
  nameAsInPan             String?
  dateAsInPan             String?
  panMasked               String?
  panFingerprint          String?             @unique
  gst                     String?
  gstMasked               String?
  gstFingerprint          String?             @unique
  website                 String?
  state                   String?
  district                String?
  officeZoneName          String?
  representativeName      String?
  designation             String?
  dateOfRetirement        String?
  department              String?
  email                   String?
  mobile                  String
  alternateMobile         String?
  stdCode                 String?
  officeContact           String?
  extensionNo             String?
  bankIfsc                String?
  bankName                String?
  bankAddress             String?
  bankAccountNo           String?
  accountHolderName       String?
  competentAuthorityEmail String?
  verifyingFirstName      String?
  verifyingLastName       String?
  verifyingEmail          String?
  verifyingMobile         String?
  verifyingDesignation    String?
  /// @deprecated Raw Aadhaar must not be written or returned. Retained temporarily for backward-compatible migrations only.
  aadhaarNumber           String?
  aadhaarMasked           String?
  aadhaarHash             String?             @unique
  aadhaarFingerprint      String?             @unique
  aadhaarVerified         Boolean             @default(false)
  country                 String              @default("India")
  city                    String?
  pincode                 String?
  registeredAddress       String?
  corporateAddress        String?
  procurementCategories   String[]
  otherCategoryDetails    String?
  annualBudget            String?
  preferredMethods        String[]
  otherMethodDetails      String?
  declarationAccepted     Boolean             @default(false)
  termsAccepted           Boolean             @default(false)
  documents               Json?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  organization            Organization?       @relation(fields: [organizationId], references: [id])
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationTypeEnum])
  @@index([verificationStatusEnum])
  @@index([gstFingerprint])
  @@index([panFingerprint])
  @@index([aadhaarHash])
}

model SellerProfile {
  id                           Int                 @id @default(autoincrement())
  userId                       Int                 @unique
  organizationId               Int?
  organizationType             String?
  organizationTypeEnum         OrganizationType?
  pan                          String              @unique
  panMasked                    String?
  panFingerprint               String?             @unique
  nameAsInPan                  String?
  dateAsInPan                  DateTime?
  panVerified                  Boolean             @default(false)
  businessName                 String?
  dateOfIncorporation          DateTime?
  detailsUpdated               Boolean             @default(false)
  isStartup                    Boolean             @default(false)
  isUdyamCertified             Boolean             @default(false)
  participateInBid             Boolean             @default(false)
  turnoverMax3Yrs              String?
  eInvoicingExcluded           Boolean             @default(false)
  ownershipDeclarationAccepted Boolean             @default(false)
  ownershipVerified            Boolean             @default(false)
  mobile                       String?
  dob                          DateTime?
  roleInOrg                    String?
  msmeCategory                 String?
  msmeCategoryEnum             MSMECategory?
  verificationStatusEnum       VerificationStatus?
  productCategories            String[]
  otherCategoryDetails         String?
  productList                  String?
  detailedProductName          String?
  hsnCode                      String?
  brand                        String?
  specifications               String?
  documents                    Json?
  /// @deprecated Raw Aadhaar must not be written or returned. Retained temporarily for backward-compatible migrations only.
  aadhaarNumber                String?
  aadhaarMasked                String?
  aadhaarHash                  String?             @unique
  aadhaarFingerprint           String?             @unique
  aadhaarVerified              Boolean             @default(false)
  termsAccepted                Boolean             @default(false)
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  catalogType                  String?
  msmeType                     String?
  vendorType                   String?
  registrationTypes            String[]
  bankAccounts                 SellerBankAccount[]
  offices                      SellerOffice[]
  organization                 Organization?       @relation(fields: [organizationId], references: [id])
  certifications               Certification[]
  sellerDocuments              SellerDocument[]
  user                         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationTypeEnum])
  @@index([msmeCategoryEnum])
  @@index([verificationStatusEnum])
  @@index([panFingerprint])
  @@index([aadhaarHash])
  @@index([aadhaarFingerprint])
}

model Organization {
  id                           Int                   @id @default(autoincrement())
  organizationName             String
  organizationType             OrganizationType
  gstin                        String?
  panNumber                    String?
  cinNumber                    String?
  udyamNumber                  String?
  addressLine1                 String?
  addressLine2                 String?
  city                         String?
  district                     String?
  state                        String?
  pincode                      String?
  country                      String                @default("India")
  website                      String?
  organizationLogoFileId       Int?
  companyId                    Int?
  annualTurnover               Decimal?              @db.Decimal(18, 2)
  employeeCount                Int?
  verificationStatus           VerificationStatus    @default(PENDING)
  organizationOnboardingStatus String?
  isBlacklisted                Boolean               @default(false)
  blacklistReason              String?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  deletedAt                    DateTime?
  gstReuseAllowed              Boolean               @default(false)
  gstReuseAllowedBy            Int?
  gstReuseAllowedAt            DateTime?
  gstReuseReason               String?
  previousOrganizationId       Int?
  replacementOrganizationId    Int?
  closedAt                     DateTime?
  closedBy                     Int?
  archivedAt                   DateTime?
  archivedBy                   Int?
  closureReason                String?
  users                        User[]
  company                      Company?              @relation(fields: [companyId], references: [id])
  buyerProfiles                BuyerProfile[]
  sellerProfiles               SellerProfile[]
  shgProfiles                  ShgProfile[]
  logoFile                     FileAsset?            @relation("OrganizationLogo", fields: [organizationLogoFileId], references: [id])
  fraudAlerts                  FraudAlert[]
  categories                   Category[]
  products                     Product[]
  services                     Service[]
  requirements                 Requirement[]
  tenders                      Tender[]
  memberships                  OrgMembership[]
  userRoles                    UserRole[]
  invitations                  OrgInvitation[]
  customRoles                  OrgCustomRole[]
  disputesRaised               Dispute[]             @relation("DisputeRaisedOrg")
  disputesAgainst              Dispute[]             @relation("DisputeAgainstOrg")
  disputesAsBuyer              Dispute[]             @relation("DisputeBuyerOrg")
  disputesAsSeller             Dispute[]             @relation("DisputeSellerOrg")
  disputeMessages              DisputeMessage[]      @relation("DisputeMessageOrg")
  accessTransferLogs           AccessTransferLog[]
  carts                        Cart[]
  buyerRequirements            BuyerRequirement[]    @relation("BuyerRequirementOrganization")
  requirementResponses         RequirementResponse[] @relation("RequirementResponseOrganization")
  guestCartItems               GuestCartItem[]
  profile                      OrganizationProfile?
  procurementApprovals         ProcurementApproval[]
  grns                         GoodsReceiptNote[]
  procurementBids              ProcurementBid[]      @relation("ProcurementBidOrganization")
  marketplaceInteractions      MarketplaceInteraction[] @relation("MarketplaceInteractionOrganization")

  @@index([organizationName])
  @@index([organizationType])
  @@index([gstin])
  @@index([panNumber])
  @@index([udyamNumber])
  @@index([verificationStatus])
  @@index([isBlacklisted])
  @@index([organizationLogoFileId])
  @@index([companyId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([state])
}

model Company {
  id                Int                @id @default(autoincrement())
  name              String
  shortName         String?
  portalDisplayName String
  logoUrl           String?
  contactEmail      String?
  contactPhone      String?
  address           String?
  district          String?
  state             String?
  themeSettings     Json?
  homepageContent   String?
  aboutContent      String?
  footerContent     String?
  grievanceContent  String?
  procurementPolicy String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
  organizations     Organization[]
  roles             RbacRole[]
  userRoles         UserRole[]
  features          CompanyFeature[]
  settings          CompanySetting[]
  contentPages      ContentPage[]
  auditLogs         AuditLog[]
  buyerRequirements BuyerRequirement[]
  guestCarts        GuestCart[]

  @@index([name])
  @@index([district, state])
  @@index([isActive])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([portalDisplayName])
}

model BuyerRequirement {
  id                  Int                    @id @default(autoincrement())
  companyId           Int?
  buyerOrganizationId Int?
  title               String
  requirementType     BuyerRequirementType
  categoryId          Int?
  description         String
  quantity            Decimal?               @db.Decimal(18, 3)
  unit                String?
  location            String?
  budgetMin           Decimal?               @db.Decimal(18, 2)
  budgetMax           Decimal?               @db.Decimal(18, 2)
  lastDate            DateTime
  visibility          RequirementVisibility  @default(PUBLIC)
  status              BuyerRequirementStatus @default(DRAFT)
  isFeatured          Boolean                @default(false)
  isUrgent            Boolean                @default(false)
  requiredDocuments   String[]               @default([])
  contactPerson       String?
  attachmentUrl       String?
  terms               String?
  approvedById        Int?
  approvedAt          DateTime?
  rejectionReason     String?
  createdById         Int?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  company             Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  buyerOrganization   Organization?          @relation("BuyerRequirementOrganization", fields: [buyerOrganizationId], references: [id], onDelete: SetNull)
  category            Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy           User?                  @relation("BuyerRequirementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy          User?                  @relation("BuyerRequirementApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  responses           RequirementResponse[]

  @@index([companyId])
  @@index([buyerOrganizationId])
  @@index([categoryId])
  @@index([status, lastDate])
  @@index([status, createdAt])
  @@index([status, isUrgent, lastDate])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isFeatured])
  @@index([isUrgent])
  @@index([createdById])
  @@index([approvedById])
}

model RequirementResponse {
  id                   Int                       @id @default(autoincrement())
  requirementId        Int
  sellerOrganizationId Int?
  sellerUserId         Int
  offeredPrice         Decimal?                  @db.Decimal(18, 2)
  offeredQuantity      Decimal?                  @db.Decimal(18, 3)
  deliveryTimeline     String?
  message              String
  attachmentUrl        String?
  terms                String?
  status               RequirementResponseStatus @default(SUBMITTED)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  requirement          BuyerRequirement          @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  sellerOrganization   Organization?             @relation("RequirementResponseOrganization", fields: [sellerOrganizationId], references: [id], onDelete: SetNull)
  sellerUser           User                      @relation("RequirementResponseSeller", fields: [sellerUserId], references: [id], onDelete: Cascade)

  @@index([requirementId])
  @@index([requirementId, createdAt])
  @@index([requirementId, sellerUserId, status])
  @@index([sellerOrganizationId])
  @@index([sellerOrganizationId, createdAt])
  @@index([sellerUserId])
  @@index([sellerUserId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model GuestCart {
  id        Int             @id @default(autoincrement())
  cartToken String          @unique
  companyId Int?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  company   Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  items     GuestCartItem[]

  @@index([companyId])
  @@index([updatedAt])
}

model GuestCartItem {
  id                   Int           @id @default(autoincrement())
  guestCartId          Int
  itemType             CartItemType
  productId            Int?
  serviceId            Int?
  quantity             Decimal       @db.Decimal(18, 3)
  priceSnapshot        Decimal?      @db.Decimal(18, 2)
  sellerOrganizationId Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  guestCart            GuestCart     @relation(fields: [guestCartId], references: [id], onDelete: Cascade)
  product              Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  service              Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  sellerOrganization   Organization? @relation(fields: [sellerOrganizationId], references: [id], onDelete: SetNull)

  @@unique([guestCartId, itemType, productId, serviceId])
  @@index([guestCartId])
  @@index([productId])
  @@index([serviceId])
  @@index([sellerOrganizationId])
}

model OrganizationProfile {
  id                 Int                @id @default(autoincrement())
  organizationId     Int                @unique
  organizationType   OrganizationType?
  industryType       String?
  logoUrl            String?
  description        String?
  isLargeIndustry    Boolean            @default(false)
  isBigMsme          Boolean            @default(false)
  isFeatured         Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([isLargeIndustry])
  @@index([isBigMsme])
  @@index([isFeatured])
  @@index([verificationStatus])
}

model SellerOffice {
  id              Int           @id @default(autoincrement())
  sellerProfileId Int
  name            String
  type            String
  gstRegistered   Boolean       @default(false)
  gstNumber       String?
  gstMasked       String?
  gstFingerprint  String?       @unique
  declaringAs     String?
  pincode         String
  state           String
  city            String
  address         String
  contactNumber   String?
  isMandatory     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId])
  @@index([gstFingerprint])
}

model SellerBankAccount {
  id                  Int           @id @default(autoincrement())
  sellerProfileId     Int
  ifsc                String
  bankName            String
  bankAddress         String
  holderName          String
  /// @deprecated Raw bank account number must not be written or returned. Retained temporarily for backward-compatible migrations only.
  accountNumber       String?
  accountNumberMasked String?
  accountNumberHash   String?       @unique
  bankFingerprint     String?       @unique
  isPrimary           Boolean       @default(false)
  isVerified          Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  sellerProfile       SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId])
  @@index([bankFingerprint])
}

model UserSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  refreshTokenHash String
  deviceId         String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RbacRole {
  id           Int              @id @default(autoincrement())
  code         String           @unique
  name         String
  description  String?
  companyId    Int?
  scope        RoleScope        @default(GLOBAL)
  isSystemRole Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  permissions  RolePermission[]
  company      Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
