generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                @id @default(autoincrement())
  name                    String
  email                   String             @unique
  userId                  String?            @unique
  password                String
  role                    Role
  registrationStatus      RegistrationStatus @default(incomplete)
  onboardingStatus        OnboardingStatus   @default(pending)
  sectionStatus           Json?
  sectionRejectionReasons Json?
  registrationDetails     Json?
  adminFeedback           String?            @default("")
  mobile                  String?
  dob                     DateTime?
  isDualRole              Boolean            @default(false)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  Approval                Approval[]
  AuditLog                AuditLog[]
  bids                    Bid[]
  buyerProfile            BuyerProfile?
  sentRequests            QuoteRequest[]     @relation("BuyerRequests")
  receivedRequests        QuoteRequest[]     @relation("SellerRequests")
  sellerProfile           SellerProfile?
  tenders                 Tender[]
}

model BuyerProfile {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  organizationName      String
  businessType          String
  industry              String?
  cin                   String?
  pan                   String?
  gst                   String?
  website               String?
  state                 String?
  district              String?
  officeZoneName        String?
  representativeName    String?
  designation           String?
  department            String?
  email                 String?
  mobile                String
  alternateMobile       String?
  aadhaarNumber         String?
  aadhaarVerified       Boolean  @default(false)
  country               String   @default("India")
  city                  String?
  pincode               String?
  registeredAddress     String?
  corporateAddress      String?
  procurementCategories String[]
  otherCategoryDetails  String?
  annualBudget          String?
  preferredMethods      String[]
  otherMethodDetails    String?
  declarationAccepted   Boolean  @default(false)
  termsAccepted         Boolean  @default(false)
  documents             Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerProfile {
  id                           Int                 @id @default(autoincrement())
  userId                       Int                 @unique
  organizationType             String?
  pan                          String              @unique
  nameAsInPan                  String?
  dateAsInPan                  DateTime?
  panVerified                  Boolean             @default(false)
  businessName                 String?
  dateOfIncorporation          DateTime?
  detailsUpdated               Boolean             @default(false)
  isStartup                    Boolean             @default(false)
  isUdyamCertified             Boolean             @default(false)
  participateInBid             Boolean             @default(false)
  optForSahay                  Boolean             @default(false)
  turnoverMax3Yrs              String?
  eInvoicingExcluded           Boolean             @default(false)
  ownershipDeclarationAccepted Boolean             @default(false)
  ownershipVerified            Boolean             @default(false)
  mobile                       String?
  dob                          DateTime?
  roleInOrg                    String?
  msmeCategory                 String?
  productCategories            String[]
  otherCategoryDetails         String?
  productList                  String?
  detailedProductName          String?
  hsnCode                      String?
  brand                        String?
  specifications               String?
  documents                    Json?
  aadhaarNumber                String?
  aadhaarVerified              Boolean             @default(false)
  termsAccepted                Boolean             @default(false)
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  catalogType                  String?
  bankAccounts                 SellerBankAccount[]
  offices                      SellerOffice[]
  user                         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerOffice {
  id              Int           @id @default(autoincrement())
  sellerProfileId Int
  name            String
  type            String
  gstRegistered   Boolean       @default(false)
  gstNumber       String?
  declaringAs     String?
  pincode         String
  state           String
  city            String
  address         String
  contactNumber   String?
  isMandatory     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
}

model SellerBankAccount {
  id              Int           @id @default(autoincrement())
  sellerProfileId Int
  ifsc            String
  bankName        String
  bankAddress     String
  holderName      String
  accountNumber   String
  isPrimary       Boolean       @default(false)
  isVerified      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
}

model Tender {
  id          Int          @id @default(autoincrement())
  buyerId     Int
  tenderId    String       @unique
  title       String
  category    String
  budget      Float
  description String
  documentUrl String?
  status      TenderStatus @default(draft)
  bidsCount   Int          @default(0)
  closesAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  Auction     Auction?
  bids        Bid[]
  buyer       User         @relation(fields: [buyerId], references: [id])
}

model Bid {
  id            Int      @id @default(autoincrement())
  tenderId      Int
  tender        Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  sellerId      Int
  seller        User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  unitPrice     Float
  quantity      Int
  deliveryDays  Int
  warranty      String?
  validTill     DateTime?
  note          String?
  status        String   @default("pending") // pending, accepted, rejected
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([tenderId, sellerId], name: "bidCompoundId")
}

model Otp {
  id         Int      @id @default(autoincrement())
  email      String
  otp        String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}

model QuoteRequest {
  id        Int      @id @default(autoincrement())
  buyerId   Int
  sellerId  Int
  subject   String
  message   String
  documentUrl String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  buyer     User     @relation("BuyerRequests", fields: [buyerId], references: [id])
  seller    User     @relation("SellerRequests", fields: [sellerId], references: [id])
}

model Approval {
  id         Int      @id @default(autoincrement())
  userId     Int
  entityType String
  entityId   Int
  status     String   @default("approved")
  remarks    String?
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Auction {
  id         Int      @id @default(autoincrement())
  tenderId   Int      @unique
  startPrice Float
  currentBid Float?
  startTime  DateTime
  endTime    DateTime
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Tender     Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  entityType String?
  entityId   Int?
  details    Json?
  createdAt  DateTime @default(now())
  User       User?    @relation(fields: [userId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GstCache {
  id                     Int       @id @default(autoincrement())
  gstNumber              String    @unique
  legalBusinessName      String
  tradeName              String?
  constitutionOfBusiness String?
  registrationDate       DateTime?
  taxpayerType           String?
  businessAddress        String?
  state                  String?
  pincode                String?
  lastVerified           DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

enum Role {
  seller
  buyer
  admin
}

enum RegistrationStatus {
  incomplete
  completed
}

enum OnboardingStatus {
  pending
  pending_validation
  under_compliance_review
  resubmission_required
  approved_for_procurement
  rejected
}

enum TenderStatus {
  draft
  approved
  published
  bid_submission
  tech_bid_opening
  tech_evaluation
  financial_bid_opening
  financial_opening
  financial_evaluation
  awarded
  po_generated
  closed
}
