  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Auction {
  id               Int            @id @default(autoincrement())
  tenderId         Int            @unique
  startPrice       Float
  currentBid       Float?
  currentLowestBid Decimal?       @db.Decimal(18, 2)
  currentWinnerId  Int?
  minDecrement     Float          @default(1)
  startTime        DateTime
  endTime          DateTime
  status           String         @default("scheduled")
  statusEnum       AuctionStatus?
  finalizedAt      DateTime?
  winnerSellerId   Int?
  overrideReason   String?
