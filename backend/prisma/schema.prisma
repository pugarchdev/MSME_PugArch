  trackingNumber       String?                 @unique
  carrierName          String?
  status               DeliveryStatus          @default(CREATED)
  expectedDelivery     DateTime?
  actualDelivery       DateTime?
  currentLocation      String?
  sellerAcceptedAt     DateTime?
  sellerRejectedAt     DateTime?
  sellerRejectReason   String?
  packedAt             DateTime?
  pickupScheduledAt    DateTime?
  pickedUpAt           DateTime?
  packageWeightKg      Decimal?                @db.Decimal(10, 3)
  packageDimensions    String?
  packageCount         Int?
  logisticsPartnerId   Int?
  logisticsPartnerName String?
  logisticsContact     String?
  ewayBillNumber       String?
  courierReceiptNumber String?
  remarks              String?
  metadata             Json?
  closedAt             DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  purchaseOrder        PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
