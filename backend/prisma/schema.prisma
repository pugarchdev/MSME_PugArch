// ─── Intra-Organisation Roles ────────────────────────────────────────────────
enum OrgRole {
  ORG_ADMIN
  PROCUREMENT_OFFICER
  FINANCE_OFFICER
  TECHNICAL_OFFICER
  LOGISTICS_OFFICER
  VIEWER
}

model OrgMembership {
  id                          Int       @id @default(autoincrement())
  userId                      Int
  organizationId              Int
  orgRole                     OrgRole   @default(VIEWER)
  customRoleId                Int?
  isActive                    Boolean   @default(true)
  invitedById                 Int?
  invitedAt                   DateTime  @default(now())
  acceptedAt                  DateTime?
  accessTransferredFromUserId Int?
  deactivatedAt               DateTime?
  deactivatedByUserId         Int?
  deactivationReason          String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  user                      User           @relation("OrgMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  organization              Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customRole                OrgCustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  invitedBy                 User?          @relation("OrgMembershipInviter", fields: [invitedById], references: [id])
  accessTransferredFromUser User?          @relation("OrgMembershipTransferSource", fields: [accessTransferredFromUserId], references: [id], onDelete: SetNull)
  deactivatedBy             User?          @relation("OrgMembershipDeactivator", fields: [deactivatedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, organizationId])
  @@index([organizationId, orgRole])
  @@index([organizationId, customRoleId])
  @@index([userId])
  @@index([invitedById])
  @@index([isActive])
  @@index([deactivatedByUserId])
}

model OrgInvitation {
  id                           Int                 @id @default(autoincrement())
  organizationId               Int
  email                        String
  invitedEmail                 String?
  orgRole                      OrgRole
  customRoleId                 Int?
  token                        String              @unique
  expiresAt                    DateTime
  status                       OrgInvitationStatus @default(PENDING)
  message                      String?
  requiresPersonalVerification Boolean             @default(true)
  acceptedAt                   DateTime?
  invitedById                  Int
  createdAt                    DateTime            @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customRole   OrgCustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  invitedBy    User           @relation("OrgInvitationInviter", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customRoleId])
  @@index([token])
  @@index([email])
}

model OrgCustomRole {
  id              Int                 @id @default(autoincrement())
  organizationId  Int
  name            String
  description     String?
  roleKey         String
  isSystemRole    Boolean             @default(false)
  isActive        Boolean             @default(true)
  createdByUserId Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User                @relation("OrgCustomRoleCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  permissions     OrgRolePermission[]
  memberships     OrgMembership[]
  invitations     OrgInvitation[]
  accessTransfers AccessTransferLog[]

  @@unique([organizationId, roleKey])
  @@index([organizationId, isActive])
  @@index([createdByUserId])
}

model OrgRolePermission {
  id            Int           @id @default(autoincrement())
  roleId        Int
  permissionKey String
  allowed       Boolean       @default(true)
  createdAt     DateTime      @default(now())
  role          OrgCustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionKey])
  @@index([roleId])
  @@index([permissionKey])
}

model AccessTransferLog {
  id                Int                  @id @default(autoincrement())
  organizationId    Int
  fromUserId        Int
  toUserId          Int?
  toEmail           String?
  roleId            Int?
  performedByUserId Int
  reason            String
  status            AccessTransferStatus @default(INITIATED)
  createdAt         DateTime             @default(now())
  completedAt       DateTime?
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromUser          User                 @relation("AccessTransferFromUser", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser            User?                @relation("AccessTransferToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  role              OrgCustomRole?       @relation(fields: [roleId], references: [id], onDelete: SetNull)
  performedBy       User                 @relation("AccessTransferPerformer", fields: [performedByUserId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([roleId])
  @@index([performedByUserId])
}

// ─── Cart System ─────────────────────────────────────────────────────────────
enum CartStatus {
  ACTIVE
  SUBMITTED_FOR_APPROVAL
  APPROVED
  REJECTED
  CONVERTED_TO_ORDER
  ABANDONED
}

model Cart {
  id             Int        @id @default(autoincrement())
  organizationId Int
  createdById    Int
  status         CartStatus @default(ACTIVE)
  notes          String?
  approvedById   Int?
  approvedAt     DateTime?
  rejectedById   Int?
  rejectedAt     DateTime?
  rejectionNote  String?
  convertedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CartCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy   User?        @relation("CartApprover", fields: [approvedById], references: [id])
  rejectedBy   User?        @relation("CartRejecter", fields: [rejectedById], references: [id])
  items        CartItem[]

  @@index([organizationId, status])
  @@index([createdById])
  @@index([approvedById])
  @@index([rejectedById])
}

model CartItem {
  id                    Int       @id @default(autoincrement())
  cartId                Int
  productId             Int?
  serviceId             Int?
  sellerId              Int
  itemName              String
  quantity              Decimal   @db.Decimal(18, 3)
  unitOfMeasure         String
  unitPrice             Decimal   @db.Decimal(18, 2)
  currency              String    @default("INR")
  technicalApproved     Boolean?
  technicalApprovedById Int?
  technicalNote         String?
  technicalDecidedAt    DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  cart                Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  service             Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  seller              User     @relation("CartItemSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  technicalApprovedBy User?    @relation("CartItemTechApprover", fields: [technicalApprovedById], references: [id])

  @@index([cartId])
  @@index([productId])
  @@index([serviceId])
  @@index([sellerId])
  @@index([technicalApprovedById])
}

// ─── Multi-Level Procurement Approval Workflow ───────────────────────────────
enum ApprovalStage {
  DEPARTMENT_HEAD
  FINANCE_DEPT
  PROCUREMENT_HEAD
}

enum ApprovalDecision {
  PENDING
  APPROVED
  REJECTED
  SENT_FOR_CLARIFICATION
}

model ProcurementApproval {
  id                Int              @id @default(autoincrement())
  entityType        String // 'tender' | 'purchase_order' | 'cart' | 'direct_purchase'
  entityId          Int
  organizationId    Int
  stage             ApprovalStage
  sequence          Int // 1, 2, 3 — order in the chain
  decision          ApprovalDecision @default(PENDING)
  approverId        Int?
  remarks           String?
  clarificationNote String?
  decidedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approver     User?        @relation("ProcurementApprovalApprover", fields: [approverId], references: [id])

  @@unique([entityType, entityId, stage])
  @@index([entityType, entityId])
  @@index([organizationId, stage, decision])
  @@index([approverId])
}

// ─── Goods Receipt Note (GRN) ────────────────────────────────────────────────
enum GrnStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PARTIAL
}

model GoodsReceiptNote {
  id              Int       @id @default(autoincrement())
  grnNumber       String    @unique
  purchaseOrderId Int
  receivedById    Int
  organizationId  Int
  status          GrnStatus @default(DRAFT)
  receivedAt      DateTime  @default(now())
  remarks         String?
  inspectionNote  String?
  approvedById    Int?
  approvedAt      DateTime?
  rejectedById    Int?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receivedBy    User          @relation("GrnReceiver", fields: [receivedById], references: [id], onDelete: Restrict)
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items         GrnItem[]
  documents     GrnDocument[]

  @@index([purchaseOrderId])
  @@index([organizationId, status])
  @@index([receivedById])
  @@index([createdAt])
  @@index([updatedAt])
}

model GrnItem {
  id                  Int      @id @default(autoincrement())
  grnId               Int
  purchaseOrderItemId Int?
  itemName            String
  orderedQty          Decimal  @db.Decimal(18, 3)
  receivedQty         Decimal  @db.Decimal(18, 3)
  acceptedQty         Decimal  @db.Decimal(18, 3)
  rejectedQty         Decimal  @db.Decimal(18, 3)
  rejectionReason     String?
  unitOfMeasure       String
  createdAt           DateTime @default(now())

  grn GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@index([grnId])
}

model GrnDocument {
  id           Int      @id @default(autoincrement())
  grnId        Int
  fileAssetId  Int
  documentType String
  uploadedById Int
  createdAt    DateTime @default(now())

  grn        GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  fileAsset  FileAsset        @relation(fields: [fileAssetId], references: [id])
  uploadedBy User             @relation("GrnDocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([grnId])
  @@index([fileAssetId])
  @@index([uploadedById])
}

