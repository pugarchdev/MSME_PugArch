  grantedByUserId Int?
  revokedByUserId Int?
  usedAt          DateTime?
  expiresAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([organizationId, month, year, eligibilityType])
  @@index([organizationId, isEligible])
  @@index([month, year, eligibilityType])
  @@index([rankId])
}

model MarketplaceNotice {
