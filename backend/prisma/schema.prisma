model MarketplaceBanner {
  id               Int                   @id @default(autoincrement())
  companyId        Int?
  districtId       Int?
  title            String
  subtitle         String?
  imageUrl         String?
  documentId       Int?
  ctaText          String?
  ctaLink          String?
  targetUrl        String?
  uploadedByOrgId  Int?
  uploadedByUserId Int?
  bannerType       BannerType            @default(DEFAULT_ADMIN)
  status           BannerStatus          @default(ACTIVE)
  startAt          DateTime?
  endAt            DateTime?
  durationDays     Int                   @default(10)
  priority         Int                   @default(0)
  displayLocation  BannerDisplayLocation @default(HOME_HERO)
  rejectionReason  String?
