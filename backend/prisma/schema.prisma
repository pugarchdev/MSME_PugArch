  deliveryStatusLogs  DeliveryStatusLog[] @relation("DeliveryStatusLogFile")
  grnDocuments        GrnDocument[]

  @@index([ownerId])
  @@index([entityType, entityId])
  @@index([checksum])
  @@index([status])
  @@index([storageProviderEnum])
  @@index([fileStatus])
}

model PurchaseOrder {
  id                Int                  @id @default(autoincrement())
  poNumber          String               @unique
  tenderId          Int?
  bidId             Int?                 @unique
  buyerId           Int
  sellerId          Int
  purchaseRequestId Int?
  contractId        Int?
  title             String
  amount            Decimal              @db.Decimal(18, 2)
  totalValue        Float
  currency          String               @default("INR")
  status            String               @default("generated")
  poStatus          POStatus?
  sourceType        String?
  sourceId          Int?
  pdfFileId         Int?
  expectedDelivery  DateTime?
  deliveryAddress   String?
  amendmentHistory  Json?
  version           Int                  @default(0)
  paymentTerms      String?
  deliveryType      String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  acceptedAt        DateTime?
  tender            Tender?              @relation(fields: [tenderId], references: [id], onDelete: Restrict)
  bid               Bid?                 @relation(fields: [bidId], references: [id], onDelete: Restrict)
  pdfFile           FileAsset?           @relation("PurchaseOrderPdf", fields: [pdfFileId], references: [id], onDelete: SetNull)
  buyer             User                 @relation("BuyerPurchaseOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  seller            User                 @relation("SellerPurchaseOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  items             PurchaseOrderItem[]
  deliveryWorkflow  DeliveryWorkflow?
  deliveryTrackings DeliveryTracking[]
  escrowAccounts    EscrowAccount[]
  inspectionRecord  InspectionRecord?
  inspectionReports InspectionReport[]
  invoices          Invoice[]
  payments          PaymentTransaction[]
  contract          Contract?            @relation(fields: [contractId], references: [id], onDelete: SetNull)
  grns              GoodsReceiptNote[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([tenderId])
  @@index([poStatus])
  @@index([sourceType, sourceId])
  @@index([pdfFileId])
}

model DeliveryWorkflow {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int           @unique
  status          String        @default("created")
  version         Int           @default(0)
