model OrganizationMonthlyRank {
  id                 Int                  @id @default(autoincrement())
  organizationId     Int
  organizationType   OrganizationRankType
  month              Int
  year               Int
  totalPurchaseValue Decimal              @default(0) @db.Decimal(18, 2)
  totalSalesValue    Decimal              @default(0) @db.Decimal(18, 2)
  orderCount         Int                  @default(0)
  rank               Int
  computedAt         DateTime             @default(now())

  @@unique([organizationId, organizationType, month, year])
  @@index([month, year, organizationType, rank])
  @@index([organizationId])
}

model BannerEligibility {
