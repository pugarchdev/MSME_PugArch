  @@index([participationId, documentCategory])
  @@index([bidId, sellerId])
}

model ProcurementBidClarification {
  id                Int                            @id @default(autoincrement())
  bidId             Int
  participationId   Int
  sellerId          Int
  buyerId           Int
  requestNumber     String                         @unique
  clarificationType String
  question          String
  response          String?
