  @@index([parentId])
  @@index([organizationId])
  @@index([type])
  @@index([isActive])
}

model Product {
  id                 Int                    @id @default(autoincrement())
  sellerId           Int
  organizationId     Int?
  categoryId         Int?
  name               String
  description        String?
  sku                String?
  hsnCode            String?
  brand              String?
  modelNumber        String?
  unitOfMeasure      String?
  price              Decimal?               @db.Decimal(18, 2)
  taxRate            Decimal?               @default(0.00) @db.Decimal(5, 2)
  discount           Decimal?               @default(0.00) @db.Decimal(5, 2)
  originalPrice      Decimal?               @db.Decimal(18, 2)
  discountPrice      Decimal?               @db.Decimal(18, 2)
  discountPercent    Decimal?               @db.Decimal(5, 2)
  offerLabel         String?
  offerStartAt       DateTime?
  offerEndAt         DateTime?
  isOfferActive      Boolean                @default(false)
  bulkDealAvailable  Boolean                @default(false)
  bulkMinQuantity    Decimal?               @db.Decimal(18, 3)
  currency           String                 @default("INR")
  status             ProductStatus          @default(DRAFT)
  isMsmeMade         Boolean                @default(false)
  itemCondition      String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  seller             User                   @relation("ProductSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  organization       Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  category           Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images             ProductImage[]
  specifications     ProductSpecification[]
  certifications     Certification[]
  requirementItems   RequirementItem[]
  tenderItems        TenderItem[]
  bidItems           BidItem[]
  purchaseOrderItems PurchaseOrderItem[]
  invoiceItems       InvoiceItem[]
  cartItems          CartItem[]
  guestCartItems     GuestCartItem[]

  @@index([sellerId])
  @@index([organizationId])
  @@index([categoryId])
  @@index([status])
  @@index([isOfferActive])
  @@index([offerStartAt, offerEndAt])
  @@index([sku])
}

