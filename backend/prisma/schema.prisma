  seller        User                              @relation("ProcurementBidClarificationSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  buyer         User                              @relation("ProcurementBidClarificationBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  requestedBy   User                              @relation("ProcurementBidClarificationRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
