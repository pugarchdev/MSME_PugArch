generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                         @id @default(autoincrement())
  name                    String
  email                   String                      @unique
  userId                  String?                     @unique
  password                String
  role                    Role
  registrationStatus      RegistrationStatus          @default(incomplete)
  onboardingStatus        OnboardingStatus            @default(pending)
  sectionStatus           Json?
  sectionRejectionReasons Json?
  registrationDetails     Json?
  adminFeedback           String?                     @default("")
  mobile                  String?
  dob                     DateTime?
  isDualRole              Boolean                     @default(false)
  emailVerified           Boolean                     @default(false)
  mobileVerified          Boolean                     @default(false)
  twoFactorEnabled        Boolean                     @default(false)
  failedLoginCount        Int                         @default(0)
  lockedUntil             DateTime?
  lastLoginAt             DateTime?
  lastPasswordChangeAt    DateTime?
  passwordResetVersion    Int                         @default(0)
  sessionVersion          Int                         @default(0)
  organizationId          Int?
  accountStatus           UserStatus                  @default(ACTIVE)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  Approval                Approval[]
  AuditLog                AuditLog[]
  complianceViolations    ComplianceViolation[]
  fileAssets              FileAsset[]
  idempotencyKeys         IdempotencyKey[]
  loginEvents             LoginEvent[]
  escrowAccountsAsBuyer   EscrowAccount[]             @relation("EscrowBuyer")
  escrowAccountsAsSeller  EscrowAccount[]             @relation("EscrowSeller")
  milestoneApprovals      MilestoneApproval[]
  paymentsAsPayee         PaymentTransaction[]        @relation("PaymentPayee")
  paymentsAsPayer         PaymentTransaction[]        @relation("PaymentPayer")
  auctionBids             AuctionBid[]
  auctionWins             Auction[]                   @relation("AuctionWinner")
  currentAuctionWins      Auction[]                   @relation("AuctionCurrentWinner")
  buyerConversations      Conversation[]              @relation("BuyerConversations")
  sellerConversations     Conversation[]              @relation("SellerConversations")
  sentMessages            Message[]                   @relation("MessageSender")
  buyerDisputes           Dispute[]                   @relation("BuyerDisputes")
  sellerDisputes          Dispute[]                   @relation("SellerDisputes")
  raisedDisputes          Dispute[]                   @relation("RaisedDisputes")
  resolvedDisputes        Dispute[]                   @relation("ResolvedDisputes")
  disputeMessages         DisputeMessage[]            @relation("DisputeMessageSender")
  disputeEvidenceUploads  DisputeEvidence[]           @relation("DisputeEvidenceUploader")
  grievances              GrievanceTicket[]           @relation("GrievanceOwner")
  assignedGrievances      GrievanceTicket[]           @relation("GrievanceAssignee")
  grievanceComments       GrievanceComment[]          @relation("GrievanceCommentAuthor")
  grievanceUploads        GrievanceAttachment[]       @relation("GrievanceAttachmentUploader")
  bids                    Bid[]
  buyerProfile            BuyerProfile?
  buyerInvoices           Invoice[]                   @relation("BuyerInvoices")
  buyerPurchaseOrders     PurchaseOrder[]             @relation("BuyerPurchaseOrders")
  sentRequests            QuoteRequest[]              @relation("BuyerRequests")
  receivedRequests        QuoteRequest[]              @relation("SellerRequests")
  sellerInvoices          Invoice[]                   @relation("SellerInvoices")
  sellerPurchaseOrders    PurchaseOrder[]             @relation("SellerPurchaseOrders")
  sellerProfile           SellerProfile?
  tenders                 Tender[]
  organization            Organization?               @relation(fields: [organizationId], references: [id])
  sessions                UserSession[]
  sellerDocumentsVerified SellerDocument[]            @relation("SellerDocumentVerifiedBy")
  apiVerificationLogs     ApiVerificationLog[]
  apiLogs                 ApiLog[]
  fraudAlerts             FraudAlert[]                @relation("FraudAlertUser")
  reviewedFraudAlerts     FraudAlert[]                @relation("FraudAlertReviewedBy")
  products                Product[]                   @relation("ProductSeller")
  services                Service[]                   @relation("ServiceSeller")
  requirements            Requirement[]               @relation("RequirementBuyer")
  directPurchasesAsBuyer  DirectPurchase[]            @relation("DirectPurchaseBuyer")
  directPurchasesAsSeller DirectPurchase[]            @relation("DirectPurchaseSeller")
  quoteResponses          QuoteResponse[]             @relation("QuoteResponseSeller")
  tenderParticipants      TenderParticipant[]         @relation("TenderParticipantSeller")
  technicalEvaluations    TechnicalEvaluationResult[] @relation("TechnicalEvaluationEvaluator")
  financialEvaluations    FinancialEvaluation[]       @relation("FinancialEvaluationEvaluator")
  supplierRatingsGiven    SupplierRating[]            @relation("SupplierRatingBuyer")
  supplierRatingsReceived SupplierRating[]            @relation("SupplierRatingSeller")
  buyerRatingsGiven       BuyerRating[]               @relation("BuyerRatingSeller")
  buyerRatingsReceived    BuyerRating[]               @relation("BuyerRatingBuyer")
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  deliveryStatusLogs      DeliveryStatusLog[]         @relation("DeliveryStatusLogActor")
  deliveryDocumentsUploaded DeliveryDocument[]        @relation("DeliveryDocumentUploader")
  deliveryParticipantRoles DeliveryParticipant[]      @relation("DeliveryParticipantUser")
  deliveryParticipantsAssigned DeliveryParticipant[]  @relation("DeliveryParticipantAssignedBy")
  buyerAcceptances        BuyerAcceptance[]           @relation("BuyerAcceptanceActor")
  paymentSettlementsVerified  PaymentSettlement[]     @relation("PaymentSettlementInvoiceVerifier")
  paymentSettlementsApproved  PaymentSettlement[]     @relation("PaymentSettlementApprover")
  paymentSettlementsReleased  PaymentSettlement[]     @relation("PaymentSettlementReleaser")
  paymentSettlementsRejected  PaymentSettlement[]     @relation("PaymentSettlementRejecter")
  orgMemberships              OrgMembership[]         @relation("OrgMembershipUser")
  orgMembershipsInvited       OrgMembership[]         @relation("OrgMembershipInviter")
  orgInvitationsSent          OrgInvitation[]         @relation("OrgInvitationInviter")
  cartsCreated                Cart[]                  @relation("CartCreator")
  cartsApproved               Cart[]                  @relation("CartApprover")
  cartsRejected               Cart[]                  @relation("CartRejecter")
  cartItemsAsSeller           CartItem[]              @relation("CartItemSeller")
  cartItemsTechApproved       CartItem[]              @relation("CartItemTechApprover")
  procurementApprovalsDecided ProcurementApproval[]   @relation("ProcurementApprovalApprover")
  grnsReceived                GoodsReceiptNote[]      @relation("GrnReceiver")
  grnDocumentsUploaded        GrnDocument[]           @relation("GrnDocumentUploader")

  @@index([role, onboardingStatus])
  @@index([mobile])
  @@index([organizationId])
  @@index([accountStatus])
}

model BuyerProfile {
  id                     Int                 @id @default(autoincrement())
  userId                 Int                 @unique
  organizationId         Int?
  organizationName       String
  businessType           String
  msmeType               String?
  organizationType       String?
  ministry               String?
  division               String?
  employeeCount          String?
  organizationTypeEnum   OrganizationType?
  verificationStatusEnum VerificationStatus?
  industry               String?
  cin                    String?
  pan                    String?
  nameAsInPan            String?
  dateAsInPan            String?
  panMasked              String?
  panFingerprint         String?             @unique
  gst                    String?
  gstMasked              String?
  gstFingerprint         String?             @unique
  website                String?
  state                  String?
  district               String?
  officeZoneName         String?
  representativeName     String?
  designation            String?
  dateOfRetirement       String?
  department             String?
  email                  String?
  mobile                 String
  alternateMobile        String?
  stdCode                String?
  officeContact          String?
  extensionNo            String?
  bankIfsc               String?
  bankName               String?
  bankAddress            String?
  bankAccountNo          String?
  accountHolderName      String?
  competentAuthorityEmail String?
  verifyingFirstName     String?
  verifyingLastName      String?
  verifyingEmail         String?
  verifyingMobile        String?
  verifyingDesignation   String?
  /// @deprecated Raw Aadhaar must not be written or returned. Retained temporarily for backward-compatible migrations only.
  aadhaarNumber          String?
  aadhaarMasked          String?
  aadhaarHash            String?             @unique
  aadhaarFingerprint     String?             @unique
  aadhaarVerified        Boolean             @default(false)
  country                String              @default("India")
  city                   String?
  pincode                String?
  registeredAddress      String?
  corporateAddress       String?
  procurementCategories  String[]
  otherCategoryDetails   String?
  annualBudget           String?
  preferredMethods       String[]
  otherMethodDetails     String?
  declarationAccepted    Boolean             @default(false)
  termsAccepted          Boolean             @default(false)
  documents              Json?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  organization           Organization?       @relation(fields: [organizationId], references: [id])
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationTypeEnum])
  @@index([verificationStatusEnum])
  @@index([gstFingerprint])
  @@index([panFingerprint])
  @@index([aadhaarHash])
}

model SellerProfile {
  id                           Int                 @id @default(autoincrement())
  userId                       Int                 @unique
  organizationId               Int?
  organizationType             String?
  organizationTypeEnum         OrganizationType?
  pan                          String              @unique
  panMasked                    String?
  panFingerprint               String?             @unique
  nameAsInPan                  String?
  dateAsInPan                  DateTime?
  panVerified                  Boolean             @default(false)
  businessName                 String?
  dateOfIncorporation          DateTime?
  detailsUpdated               Boolean             @default(false)
  isStartup                    Boolean             @default(false)
  isUdyamCertified             Boolean             @default(false)
  participateInBid             Boolean             @default(false)
  turnoverMax3Yrs              String?
  eInvoicingExcluded           Boolean             @default(false)
  ownershipDeclarationAccepted Boolean             @default(false)
  ownershipVerified            Boolean             @default(false)
  mobile                       String?
  dob                          DateTime?
  roleInOrg                    String?
  msmeCategory                 String?
  msmeCategoryEnum             MSMECategory?
  verificationStatusEnum       VerificationStatus?
  productCategories            String[]
  otherCategoryDetails         String?
  productList                  String?
  detailedProductName          String?
  hsnCode                      String?
  brand                        String?
  specifications               String?
  documents                    Json?
  /// @deprecated Raw Aadhaar must not be written or returned. Retained temporarily for backward-compatible migrations only.
  aadhaarNumber                String?
  aadhaarMasked                String?
  aadhaarHash                  String?             @unique
  aadhaarFingerprint           String?             @unique
  aadhaarVerified              Boolean             @default(false)
  termsAccepted                Boolean             @default(false)
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  catalogType                  String?
  msmeType                     String?
  vendorType                   String?
  registrationTypes            String[]
  bankAccounts                 SellerBankAccount[]
  offices                      SellerOffice[]
  organization                 Organization?       @relation(fields: [organizationId], references: [id])
  certifications               Certification[]
  sellerDocuments              SellerDocument[]
  user                         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationTypeEnum])
  @@index([msmeCategoryEnum])
  @@index([verificationStatusEnum])
  @@index([panFingerprint])
  @@index([aadhaarHash])
  @@index([aadhaarFingerprint])
}

model Organization {
  id                           Int                @id @default(autoincrement())
  organizationName             String
  organizationType             OrganizationType
  gstin                        String?
  panNumber                    String?
  cinNumber                    String?
  udyamNumber                  String?
  addressLine1                 String?
  addressLine2                 String?
  city                         String?
  district                     String?
  state                        String?
  pincode                      String?
  country                      String             @default("India")
  website                      String?
  organizationLogoFileId       Int?
  annualTurnover               Decimal?           @db.Decimal(18, 2)
  employeeCount                Int?
  verificationStatus           VerificationStatus @default(PENDING)
  organizationOnboardingStatus String?
  isBlacklisted                Boolean            @default(false)
  blacklistReason              String?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt
  deletedAt                    DateTime?
  users                        User[]
  buyerProfiles                BuyerProfile[]
  sellerProfiles               SellerProfile[]
  logoFile                     FileAsset?         @relation("OrganizationLogo", fields: [organizationLogoFileId], references: [id])
  fraudAlerts                  FraudAlert[]
  categories                   Category[]
  products                     Product[]
  services                     Service[]
  requirements                 Requirement[]
  tenders                      Tender[]
  memberships                  OrgMembership[]
  invitations                  OrgInvitation[]
  carts                        Cart[]
  procurementApprovals         ProcurementApproval[]
  grns                         GoodsReceiptNote[]

  @@index([gstin])
  @@index([panNumber])
  @@index([udyamNumber])
  @@index([verificationStatus])
  @@index([isBlacklisted])
  @@index([organizationLogoFileId])
}

model SellerOffice {
  id              Int           @id @default(autoincrement())
  sellerProfileId Int
  name            String
  type            String
  gstRegistered   Boolean       @default(false)
  gstNumber       String?
  gstMasked       String?
  gstFingerprint  String?       @unique
  declaringAs     String?
  pincode         String
  state           String
  city            String
  address         String
  contactNumber   String?
  isMandatory     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId])
  @@index([gstFingerprint])
}

model SellerBankAccount {
  id                  Int           @id @default(autoincrement())
  sellerProfileId     Int
  ifsc                String
  bankName            String
  bankAddress         String
  holderName          String
  /// @deprecated Raw bank account number must not be written or returned. Retained temporarily for backward-compatible migrations only.
  accountNumber       String?
  accountNumberMasked String?
  accountNumberHash   String?       @unique
  bankFingerprint     String?       @unique
  isPrimary           Boolean       @default(false)
  isVerified          Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  sellerProfile       SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId])
  @@index([bankFingerprint])
}

model UserSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  refreshTokenHash String
  deviceId         String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RbacRole {
  id           Int              @id @default(autoincrement())
  code         String           @unique
  name         String
  description  String?
  isSystemRole Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  permissions  RolePermission[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  code        String           @unique
  module      String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([module])
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  role         RbacRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model SellerDocument {
  id                 Int                @id @default(autoincrement())
  sellerProfileId    Int
  documentType       String
  fileAssetId        Int
  verificationStatus VerificationStatus @default(PENDING)
  remarks            String?
  verifiedById       Int?
  verifiedAt         DateTime?
  uploadedAt         DateTime           @default(now())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sellerProfile      SellerProfile      @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  fileAsset          FileAsset          @relation(fields: [fileAssetId], references: [id])
  verifiedBy         User?              @relation("SellerDocumentVerifiedBy", fields: [verifiedById], references: [id])

  @@index([sellerProfileId])
  @@index([fileAssetId])
  @@index([verificationStatus])
  @@index([verifiedById])
}

model Category {
  id             Int           @id @default(autoincrement())
  parentId       Int?
  organizationId Int?
  name           String
  slug           String        @unique
  description    String?
  type           CategoryType  @default(BOTH)
  isActive       Boolean       @default(true)
  displayOrder   Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  parent         Category?     @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]    @relation("CategoryTree")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  products       Product[]
  services       Service[]
  requirements   Requirement[]
  tenders        Tender[]

  @@index([parentId])
  @@index([organizationId])
  @@index([type])
  @@index([isActive])
}

model Product {
  id                 Int                    @id @default(autoincrement())
  sellerId           Int
  organizationId     Int?
  categoryId         Int?
  name               String
  description        String?
  sku                String?
  hsnCode            String?
  brand              String?
  modelNumber        String?
  unitOfMeasure      String?
  price              Decimal?               @db.Decimal(18, 2)
  currency           String                 @default("INR")
  status             ProductStatus          @default(DRAFT)
  isMsmeMade         Boolean                @default(false)
  itemCondition      String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  seller             User                   @relation("ProductSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  organization       Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  category           Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images             ProductImage[]
  specifications     ProductSpecification[]
  certifications     Certification[]
  requirementItems   RequirementItem[]
  tenderItems        TenderItem[]
  bidItems           BidItem[]
  purchaseOrderItems PurchaseOrderItem[]
  invoiceItems       InvoiceItem[]
  cartItems          CartItem[]

  @@index([sellerId])
  @@index([organizationId])
  @@index([categoryId])
  @@index([status])
  @@index([sku])
}

model ProductImage {
  id           Int       @id @default(autoincrement())
  productId    Int
  fileAssetId  Int
  altText      String?
  displayOrder Int       @default(0)
  isPrimary    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  fileAsset    FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([fileAssetId])
}

model ProductSpecification {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String
  value     String
  unit      String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@index([productId])
}

model Service {
  id             Int             @id @default(autoincrement())
  sellerId       Int
  organizationId Int?
  categoryId     Int?
  name           String
  description    String?
  pricingModel   PricingModel    @default(CUSTOM)
  basePrice      Decimal?        @db.Decimal(18, 2)
  currency       String          @default("INR")
  serviceArea    String?
  status         ProductStatus   @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  seller         User            @relation("ServiceSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  category       Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  certifications Certification[]
  cartItems      CartItem[]

  @@index([sellerId])
  @@index([organizationId])
  @@index([categoryId])
  @@index([status])
}

model Certification {
  id                 Int                @id @default(autoincrement())
  sellerProfileId    Int?
  productId          Int?
  serviceId          Int?
  name               String
  issuingAuthority   String?
  certificateNumber  String?
  verificationStatus VerificationStatus @default(PENDING)
  issuedAt           DateTime?
  expiresAt          DateTime?
  fileAssetId        Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sellerProfile      SellerProfile?     @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  product            Product?           @relation(fields: [productId], references: [id], onDelete: Cascade)
  service            Service?           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  fileAsset          FileAsset?         @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)

  @@index([sellerProfileId])
  @@index([productId])
  @@index([serviceId])
  @@index([verificationStatus])
  @@index([expiresAt])
  @@index([fileAssetId])
}

model Requirement {
  id                Int               @id @default(autoincrement())
  requirementNumber String            @unique
  buyerId           Int
  organizationId    Int?
  categoryId        Int?
  title             String
  description       String?
  procurementMethod ProcurementMethod @default(TENDER)
  status            RequirementStatus @default(DRAFT)
  estimatedValue    Decimal?          @db.Decimal(18, 2)
  currency          String            @default("INR")
  requiredBy        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  buyer             User              @relation("RequirementBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  organization      Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  category          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items             RequirementItem[]
  tenders           Tender[]
  directPurchases   DirectPurchase[]

  @@index([buyerId])
  @@index([organizationId])
  @@index([categoryId])
  @@index([status])
  @@index([procurementMethod])
}

model RequirementItem {
  id                 Int          @id @default(autoincrement())
  requirementId      Int
  productId          Int?
  itemName           String
  description        String?
  quantity           Decimal      @db.Decimal(18, 3)
  unitOfMeasure      String
  estimatedUnitPrice Decimal?     @db.Decimal(18, 2)
  specifications     Json?
  createdAt          DateTime     @default(now())
  requirement        Requirement  @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  product            Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  tenderItems        TenderItem[]

  @@index([requirementId])
  @@index([productId])
}

model DirectPurchase {
  id             Int                  @id @default(autoincrement())
  requirementId  Int?
  buyerId        Int
  sellerId       Int
  purchaseNumber String               @unique
  status         DirectPurchaseStatus @default(DRAFT)
  totalAmount    Decimal?             @db.Decimal(18, 2)
  currency       String               @default("INR")
  requestedAt    DateTime             @default(now())
  approvedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  requirement    Requirement?         @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  buyer          User                 @relation("DirectPurchaseBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  seller         User                 @relation("DirectPurchaseSeller", fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([requirementId])
  @@index([buyerId, status])
  @@index([sellerId, status])
}

model QuoteResponse {
  id             Int                 @id @default(autoincrement())
  quoteRequestId Int
  sellerId       Int
  responseNumber String?             @unique
  status         QuoteResponseStatus @default(DRAFT)
  totalAmount    Decimal?            @db.Decimal(18, 2)
  currency       String              @default("INR")
  deliveryDays   Int?
  validityDate   DateTime?
  notes          String?
  documentUrl    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  quoteRequest   QuoteRequest        @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  seller         User                @relation("QuoteResponseSeller", fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([quoteRequestId])
  @@index([sellerId, status])
}

model Tender {
  id                    Int                           @id @default(autoincrement())
  buyerId               Int
  tenderId              String                        @unique
  title                 String
  category              String
  categoryId            Int?
  requirementId         Int?
  organizationId        Int?
  budget                Float
  description           String
  documentUrl           String?
  status                TenderStatus                  @default(draft)
  statusEnum            TenderStatusV2?
  bidsCount             Int                           @default(0)
  closesAt              DateTime?
  publishedAt           DateTime?
  closedAt              DateTime?
  quantityUnit          String?
  paymentTerms          String?
  deliveryType          String?
  itemCondition         String?
  awardedBidId          Int?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  Auction               Auction?
  conversations         Conversation[]
  bids                  Bid[]
  buyer                 User                          @relation(fields: [buyerId], references: [id])
  categoryRef           Category?                     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  requirement           Requirement?                  @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  organization          Organization?                 @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  awardedBid            Bid?                          @relation("AwardedBid", fields: [awardedBidId], references: [id], onDelete: SetNull)
  purchaseOrders        PurchaseOrder[]
  tenderItems           TenderItem[]
  tenderDocuments       TenderDocument[]
  tenderParticipants    TenderParticipant[]
  technicalCriteria     TechnicalEvaluationCriteria[]
  technicalResults      TechnicalEvaluationResult[]
  financialEvaluations  FinancialEvaluation[]
  comparativeStatements ComparativeStatement[]
  contracts             Contract[]

  @@index([buyerId, status])
  @@index([categoryId])
  @@index([requirementId])
  @@index([organizationId])
  @@index([statusEnum])
  @@index([awardedBidId])
  @@index([createdAt])
}

model Bid {
  id       Int    @id @default(autoincrement())
  tenderId Int
  tender   Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  sellerId Int
  seller   User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  unitPrice         Float
  quantity          Int
  deliveryDays      Int
  warranty          String?
  validTill         DateTime?
  note              String?
  documentUrl       String?
  fileAssetId       Int?
  bidNumber         String?    @unique
  withdrawnAt       DateTime?
  modifiedAt        DateTime?
  lastIpAddress     String?
  lastUserAgentHash String?
  deviceHash        String?
  status            String     @default("pending") // pending, accepted, rejected
  statusEnum        BidStatus?

  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  purchaseOrder         PurchaseOrder?
  awardedTenders        Tender[]                    @relation("AwardedBid")
  bidItems              BidItem[]
  technicalResults      TechnicalEvaluationResult[]
  financialEvaluations  FinancialEvaluation[]
  comparativeStatements ComparativeStatement[]
  contracts             Contract[]

  @@unique([tenderId, sellerId], name: "bidCompoundId")
  @@index([sellerId, status])
  @@index([tenderId, status])
  @@index([bidNumber])
  @@index([statusEnum])
}

model TenderItem {
  id                 Int              @id @default(autoincrement())
  tenderId           Int
  requirementItemId  Int?
  productId          Int?
  itemName           String
  description        String?
  quantity           Decimal          @db.Decimal(18, 3)
  unitOfMeasure      String
  estimatedUnitPrice Decimal?         @db.Decimal(18, 2)
  specifications     Json?
  createdAt          DateTime         @default(now())
  tender             Tender           @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  requirementItem    RequirementItem? @relation(fields: [requirementItemId], references: [id], onDelete: SetNull)
  product            Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  bidItems           BidItem[]

  @@index([tenderId])
  @@index([requirementItemId])
  @@index([productId])
}

model TenderDocument {
  id           Int       @id @default(autoincrement())
  tenderId     Int
  fileAssetId  Int
  documentType String
  title        String?
  isPublic     Boolean   @default(false)
  uploadedAt   DateTime  @default(now())
  tender       Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  fileAsset    FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Restrict)

  @@index([tenderId])
  @@index([fileAssetId])
  @@index([documentType])
}

model TenderParticipant {
  id          Int               @id @default(autoincrement())
  tenderId    Int
  sellerId    Int
  status      ParticipantStatus @default(INVITED)
  invitedAt   DateTime?
  respondedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tender      Tender            @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  seller      User              @relation("TenderParticipantSeller", fields: [sellerId], references: [id], onDelete: Restrict)

  @@unique([tenderId, sellerId])
  @@index([sellerId, status])
}

model BidItem {
  id           Int         @id @default(autoincrement())
  bidId        Int
  tenderItemId Int?
  productId    Int?
  quantity     Decimal     @db.Decimal(18, 3)
  unitPrice    Decimal     @db.Decimal(18, 2)
  totalPrice   Decimal     @db.Decimal(18, 2)
  taxRate      Decimal?    @db.Decimal(5, 2)
  remarks      String?
  createdAt    DateTime    @default(now())
  bid          Bid         @relation(fields: [bidId], references: [id], onDelete: Cascade)
  tenderItem   TenderItem? @relation(fields: [tenderItemId], references: [id], onDelete: SetNull)
  product      Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([bidId])
  @@index([tenderItemId])
  @@index([productId])
}

model TechnicalEvaluationCriteria {
  id          Int                         @id @default(autoincrement())
  tenderId    Int
  name        String
  description String?
  maxScore    Decimal                     @db.Decimal(8, 2)
  weightage   Decimal?                    @db.Decimal(5, 2)
  isMandatory Boolean                     @default(false)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  tender      Tender                      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  results     TechnicalEvaluationResult[]

  @@index([tenderId])
}

model TechnicalEvaluationResult {
  id          Int                         @id @default(autoincrement())
  tenderId    Int
  bidId       Int
  criteriaId  Int
  evaluatorId Int?
  score       Decimal                     @db.Decimal(8, 2)
  status      EvaluationStatus            @default(PENDING)
  remarks     String?
  evaluatedAt DateTime?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  tender      Tender                      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  bid         Bid                         @relation(fields: [bidId], references: [id], onDelete: Cascade)
  criteria    TechnicalEvaluationCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  evaluator   User?                       @relation("TechnicalEvaluationEvaluator", fields: [evaluatorId], references: [id], onDelete: SetNull)

  @@unique([bidId, criteriaId])
  @@index([tenderId])
  @@index([evaluatorId])
  @@index([status])
}

model FinancialEvaluation {
  id              Int              @id @default(autoincrement())
  tenderId        Int
  bidId           Int
  evaluatorId     Int?
  quotedAmount    Decimal          @db.Decimal(18, 2)
  evaluatedAmount Decimal?         @db.Decimal(18, 2)
  rank            Int?
  status          EvaluationStatus @default(PENDING)
  remarks         String?
  evaluatedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tender          Tender           @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  bid             Bid              @relation(fields: [bidId], references: [id], onDelete: Cascade)
  evaluator       User?            @relation("FinancialEvaluationEvaluator", fields: [evaluatorId], references: [id], onDelete: SetNull)

  @@unique([tenderId, bidId])
  @@index([tenderId])
  @@index([bidId])
  @@index([status])
}

model ComparativeStatement {
  id          Int      @id @default(autoincrement())
  tenderId    Int
  bidId       Int?
  version     Int      @default(1)
  summary     Json
  recommended Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  bid         Bid?     @relation(fields: [bidId], references: [id], onDelete: SetNull)

  @@index([tenderId])
  @@index([bidId])
  @@index([recommended])
}

model Contract {
  id             Int             @id @default(autoincrement())
  contractNumber String          @unique
  tenderId       Int?
  bidId          Int?
  contractType   ContractType    @default(PURCHASE)
  status         ContractStatus  @default(DRAFT)
  title          String
  value          Decimal         @db.Decimal(18, 2)
  currency       String          @default("INR")
  startDate      DateTime?
  endDate        DateTime?
  signedAt       DateTime?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tender         Tender?         @relation(fields: [tenderId], references: [id], onDelete: SetNull)
  bid            Bid?            @relation(fields: [bidId], references: [id], onDelete: SetNull)
  purchaseOrders PurchaseOrder[]

  @@index([tenderId])
  @@index([bidId])
  @@index([status])
  @@index([contractType])
}

model Otp {
  id         Int      @id @default(autoincrement())
  email      String
  /// @deprecated Plain OTP storage is disabled in application code. Retained temporarily for backward-compatible migrations only.
  otp        String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}

model OtpVerification {
  id             Int       @id @default(autoincrement())
  identifier     String
  identifierHash String
  purpose        String
  otpHash        String?
  otpHashes      Json?
  metadata       Json?
  attempts       Int       @default(0)
  verified       Boolean   @default(false)
  expiresAt      DateTime
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([identifierHash, purpose])
  @@index([expiresAt])
}

model QuoteRequest {
  id             Int                 @id @default(autoincrement())
  buyerId        Int
  sellerId       Int
  subject        String
  message        String
