model ProcurementBid {
  id                    Int                       @id @default(autoincrement())
  bidNumber             String                    @unique
  title                 String
  description           String
  buyerId               Int
  buyerOrganizationId   Int?
  buyerOrganizationName String
  buyerType             String
  category              String
  subCategory           String?
  bidType               String
  procurementType       String?
  quantity              Decimal?                  @db.Decimal(18, 3)
  unit                  String?
  estimatedValue        Decimal?                  @db.Decimal(18, 2)
  deliveryLocation      String
  state                 String?
  district              String?
  pincode               String?
  startDate             DateTime
  endDate               DateTime
  technicalOpeningDate  DateTime?
  financialOpeningDate  DateTime?
  bidValidityDate       DateTime?
  status                ProcurementBidStatus      @default(DRAFT)
  approvalStatus        ProcurementApprovalStatus @default(DRAFT)
  lifecycleStage        ProcurementLifecycleStage @default(BID_PUBLISHED)
  evaluationMethod      String                    @default("L1")
  isEmdRequired         Boolean                   @default(false)
  emdAmount             Decimal?                  @db.Decimal(18, 2)
  documentFee           Decimal?                  @db.Decimal(18, 2)
  allowClarification    Boolean                   @default(true)
  allowReverseAuction   Boolean                   @default(false)
  allowBoq              Boolean                   @default(false)
  termsAndConditions    String[]                  @default([])
  eligibilityCriteria   String[]                  @default([])
  requiredDocuments     String[]                  @default([])
  approvedById          Int?
  approvedAt            DateTime?
  rejectedReason        String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  buyer             User                          @relation("ProcurementBidCreatedBy", fields: [buyerId], references: [id], onDelete: Restrict)
  buyerOrganization Organization?                 @relation("ProcurementBidOrganization", fields: [buyerOrganizationId], references: [id])
  approvedBy        User?                         @relation("ProcurementBidApprovedBy", fields: [approvedById], references: [id])
  documents         ProcurementBidDocument[]
  participations    ProcurementBidParticipation[]
  clarifications    ProcurementBidClarification[]
  evaluations       ProcurementBidEvaluation[]
  awards            ProcurementBidAward[]

  @@index([status, approvalStatus])
  @@index([buyerId, status])
  @@index([buyerOrganizationId])
  @@index([category])
  @@index([district, state])
  @@index([endDate])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([estimatedValue])
  @@index([approvalStatus])
  @@index([status])
  @@index([buyerOrganizationName])
  @@index([title])
}

model ProcurementBidDocument {
  id           Int                           @id @default(autoincrement())
  bidId        Int
  documentType String
  fileAssetId  Int?
  fileName     String
  fileUrl      String?
  fileKey      String?
  mimeType     String
  fileSize     Int
  uploadedById Int
