  @@index([purchaseOrderId])
  @@index([status])
  @@index([logisticsPartnerId])
}

model DeliveryTrackingEvent {
  id                 Int              @id @default(autoincrement())
  deliveryTrackingId Int
  status             DeliveryStatus
  location           String?
  remarks            String?
  occurredAt         DateTime         @default(now())
  createdAt          DateTime         @default(now())
  deliveryTracking   DeliveryTracking @relation(fields: [deliveryTrackingId], references: [id], onDelete: Cascade)

  @@index([deliveryTrackingId])
  @@index([status])
  @@index([occurredAt])
}

model DeliveryStatusLog {
  id                 Int              @id @default(autoincrement())
  deliveryTrackingId Int
  previousStatus     DeliveryStatus?
  newStatus          DeliveryStatus
  changedById        Int?
  actorRole          String?
