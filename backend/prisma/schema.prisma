model MarketplaceInteraction {
  id             Int                         @id @default(autoincrement())
  userId         Int?
  organizationId Int?
  itemId         Int?
  itemType       CartItemType?
  categoryId     Int?
  action         MarketplaceInteractionAction
  metadata       Json?
  createdAt      DateTime                    @default(now())

  user         User?         @relation("MarketplaceInteractionUser", fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation("MarketplaceInteractionOrganization", fields: [organizationId], references: [id], onDelete: SetNull)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, action, createdAt])
  @@index([organizationId, action, createdAt])
  @@index([itemType, itemId])
  @@index([categoryId])
  @@index([createdAt])
}

