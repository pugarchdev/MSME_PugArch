  requestedById     Int
  respondedById     Int?
  requestedAt       DateTime                       @default(now())
  respondedAt       DateTime?
  dueDate           DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  bid           ProcurementBid                    @relation(fields: [bidId], references: [id], onDelete: Cascade)
