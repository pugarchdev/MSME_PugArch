NEXT_PUBLIC_API_URL=http://localhost:5001
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001
BACKEND_URL=http://localhost:5001
NEXT_PUBLIC_ENABLE_PROCUREMENT_DEMO_DATA=false

# Vercel provides these automatically during hosted builds.
VERCEL_URL=
VERCEL_GIT_COMMIT_REF=

# Production requirements:
# NEXT_PUBLIC_API_URL should be /proxy on Vercel through next.config.ts.
# BACKEND_URL or NEXT_PUBLIC_BACKEND_URL must point to the deployed backend for rewrites.
# NEXT_PUBLIC_ENABLE_PROCUREMENT_DEMO_DATA must remain false in production.
